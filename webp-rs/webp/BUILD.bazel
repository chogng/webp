load("//:defs.bzl", "webp_rust_crate")
load("@rules_rs//rs:rust_test.bzl", "rust_test")

webp_rust_crate(
    name = "webp",
    crate_name = "webp",
    # Keep Bazel's direct rustc invocation aligned with Cargo's default
    # product profile. Bazel does not apply Cargo feature defaults itself.
    rustc_flags = [
        '--cfg=feature="decode"',
        '--cfg=feature="encode"',
        '--cfg=feature="animation"',
    ],
    test_compile_data = ["//:test_data"],
    test_data = ["//:test_data"],
)

rust_test(
    name = "external_animation_corpus_test",
    crate_root = "tests/external_animation_corpus.rs",
    srcs = ["tests/external_animation_corpus.rs"],
    edition = "2024",
    data = ["//:external_corpus_data"],
    deps = [
        ":webp",
    ],
    tags = ["external-corpus", "manual"],
)

rust_test(
    name = "external_upstream_corpus_test",
    crate_root = "tests/external_upstream_corpus.rs",
    srcs = ["tests/external_upstream_corpus.rs"],
    edition = "2024",
    data = ["//:external_corpus_data"],
    deps = [
        ":webp",
        "//webp-rs/container",
    ],
    tags = ["external-corpus", "manual"],
)

rust_test(
    name = "alpha_encoder_oracle_test",
    crate_root = "tests/alpha_encoder_oracle.rs",
    srcs = ["tests/alpha_encoder_oracle.rs"],
    edition = "2024",
    data = [
        "//:external_corpus_data",
        "//:external_oracle_data",
    ],
    deps = [":webp"],
    tags = ["external-corpus", "manual"],
)
