# Local cargo-mutants reports and rotated reports.
/mutants.out/
/mutants.out.old/
# Downloaded corpora and oracle checkouts stay local. The small, curated
# pinned-libwebp benchmark record is the only tracked third-party artifact.
/third_party/*
!/third_party/benchmarks/
/third_party/benchmarks/*
!/third_party/benchmarks/README.md
!/third_party/benchmarks/libwebp/
/third_party/benchmarks/libwebp/*
!/third_party/benchmarks/libwebp/vp8l-encode.md

# Deterministic public-API fixtures are generated once into a local cache.
/tests/fixtures/generated/

# Bazel output-tree convenience symlinks and local overrides.
/.bazelrc.user
/bazel-*

# One-shot tool scratch space. Tool EXIT traps remove each run directory.
/target/temporary/

# Reproducible experiment outputs. Keep reports, manifests, provenance,
# reproducer/summarizer sources, and curated top-level summaries in Git; write
# row-level measurements and command output to the reproducer's output path.
/experiments/**/raw/
/experiments/**/measurements/
/experiments/**/screen-[0-9]*/
/experiments/**/screen-compact/
/experiments/**/screen-low-latency/
/experiments/**/formal-[0-9]*/
/experiments/**/comparative-decode-[0-9]*/
/experiments/**/libwebp-decode-[0-9]*/
/experiments/**/*.tsv
/experiments/**/*.stderr
/experiments/**/*.log
/experiments/**/processes.jsonl
/experiments/**/run.json
/experiments/**/SHA256SUMS
/experiments/**/assertions.txt
/experiments/**/decoder-*.txt
/experiments/**/invalidated-runs/**/*.txt
/experiments/**/invalidated-runs/**/*.json
/experiments/**/__pycache__/
/experiments/**/*.pyc
